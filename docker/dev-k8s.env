HOST=dev01.daddys-rgs.com
PORT=80
GAME_CORE=bdg7360

# certified RNG library version
RNG_VERSION=2.14

# shared nats instance
NATS_HOST=nats.rgs.svc.cluster.local
NATS_PORT=4222

NUM_THREADS=1
REQ_MAX_AGE=5
ENABLE_EXPRESS=yes
EXPRESS_PORT=80
RNG_MAX_RECORDS=10000
RNG_MAX_HOLD_TIME=10000
RNG_MONITOR_CHANNEL='rngmon'

# for static
GAME_STATIC_PROXY_PREFIX=/game/static

# Launcher endpoint for game library
GAME_LIB_CONFIG_EP=/config/game
LAUNCHER_SERVER_PROXY_PREFIX=/la
