+bool PayWindow::wildHookFeature (const CoinSym_Vec& coinSyms, const bool moreDynamite, SymCoords_Vec& wildSyms) {
+    auto nCoinSyms = coinSyms.size();
+    if (!(nCoinSyms >= 1 && nCoinSyms <= 14 && symbolCount(WS) == 0))
+        return false;
+
+    const double wfhProb = (moreDynamite ? WILD_HOOK_FEATURE_WITH_MORE_DYNAMITE : WILD_HOOK_FEATURE_WITHOUT_MORE_DYNAMITE);
+    const double randVal = rng.getDouble();
+    bool whfTrigerred = (randVal < wfhProb);
+
+    if (!whfTrigerred)
+        return whfTrigerred;
+
+
+    std::vector<std::pair<int, int>> nonCsPositions;
+    for (int i = 0; i < REEL_COUNT; i++) {
+        for (int j = 0; j < GRID_HEIGHT; j++) {
+            if (window[i][j] != CS)
+                nonCsPositions.push_back({i, j});
+        }
+    }
+
+    const auto nonCsPos = nonCsPositions[rng.getScaled(nonCsPositions.size())];
+    window[nonCsPos.first][nonCsPos.second] = WS;
+    wildSyms.push_back ({ nonCsPos.first, nonCsPos.second, WS });
+
+    return whfTrigerred;
+}
+
+bool PayWindow::dynamiteFeature (
+    const bool moreDynamite,
+    const WildCollection& wsCol,
+    const CoinSet& coinSet,
+    CoinSym_Vec& coinSymbols,
+    const int64_t refBetBase
+) {
+    const int nWS = symbolCount(WS);
+    if (nWS < 1 || coinSymbols.size() > 0)
+        return false;
+
+    std::map<Symbol, bool> symbols;
+    Winning_Vec winnings;
+    getWinnings (winnings, /*refBetBase=*/1, /*refWinsSoFar=*/0); // values to get winnning syms
+    std::vector<std::pair<int, int>> nonWinSymbols;
+
+    //TODO: preliminary win eval to check dynamite feature, line 193/4
+    for (auto& win: winnings)
+    symbols.insert ({ win.symbol, true });
+
+    for (int i = 0; i < REEL_COUNT; i++) {
+        for (int j = 0; j < GRID_HEIGHT; j++) {
+            const auto& sym = window[i][j];
+            if (symbols.find (sym) == symbols.end() && sym != WS) {
+                nonWinSymbols.push_back ({ i, j });
+                // NOTE: comment for non-unique(all) positions for each symbol
+                symbols.insert ({ sym, true });
+            }
+        }
+    }
+
+    if (nonWinSymbols.size() < 3)
+        return false;
+
+    const double dfProb    = (moreDynamite ? DYNAMITE_FEATURE_WITH_MORE_DYNAMITE: DYNAMITE_FEATURE_WITHOUT_MORE_DYNAMITE);
+    const double randVal   = rng.getDouble();
+    const bool dfTriggered = (randVal < dfProb);
+
+    if (!dfTriggered)
+        return dfTriggered;
+
+    const auto& [counts, weights] = DYNAMITE_FEAT_CS_SYMBOLS;
+    const int csSymsToPlace        = std::min (
+        counts[rng.getWeightedIndex (weights.data(), weights.size())],
+        static_cast<int>(nonWinSymbols.size())
+    );
+
+    while (!nonWinSymbols.empty()) {
+        const auto& randIdx = rng.getScaled (nonWinSymbols.size());
+        const auto& [i, j] = nonWinSymbols[randIdx];
+        const auto idx    = getCoinSymbolForCRRep (wsCol.activeLevel, coinSet);
+        const auto valueX = COIN_VALUES_X[idx];
+
+        window[i][j] = CS;
+        coinSymbols.push_back ({
+            i, j,
+            window[i][j], valueX,
+            valueX * refBetBase,
+            valueX * refBetBase,
+        });
+
+        nonWinSymbols.erase (nonWinSymbols.begin() + randIdx);
+    }
+
+    return dfTriggered;
 }
 
